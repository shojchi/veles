# --- Active provider: Gemini (default) ---
GEMINI_API_KEY=AIza...

# --- Alternative provider: Anthropic ---
# Set provider: "anthropic" in config/models.yaml to use these
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI-compatible: Groq (hosted) or local proxy
# OPENAI_API_KEY=gsk_...          ← Groq key from console.groq.com
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   ← Groq
# OPENAI_BASE_URL=http://localhost:8080/v1          ← local proxy
